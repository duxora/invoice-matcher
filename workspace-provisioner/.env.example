# GoDaddy API credentials (https://developer.godaddy.com/)
export GODADDY_API_KEY=your-api-key
export GODADDY_API_SECRET=your-api-secret

# GoDaddy API base URL (default: OTE test environment)
# Production: https://api.godaddy.com
# export GODADDY_BASE_URL=https://api.ote-godaddy.com

# Google service account JSON key file path
export GOOGLE_SA_KEY_FILE=/path/to/service-account.json

# Google Workspace super admin email (for domain-wide delegation)
export GOOGLE_ADMIN_EMAIL=admin@yourdomain.com
